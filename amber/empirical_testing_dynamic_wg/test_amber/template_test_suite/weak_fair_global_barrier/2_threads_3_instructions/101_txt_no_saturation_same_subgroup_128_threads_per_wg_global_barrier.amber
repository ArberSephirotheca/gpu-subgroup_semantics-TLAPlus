#!amber

SET ENGINE_DATA fence_timeout_ms 10000

SHADER compute test GLSL
#version 460
#extension GL_KHR_shader_subgroup_basic : enable
#extension GL_KHR_shader_subgroup_ballot : enable
#extension GL_KHR_shader_subgroup_vote : enable
#extension GL_KHR_shader_subgroup_shuffle : enable
#extension GL_KHR_memory_scope_semantics : enable
layout(set = 0, binding = 0) volatile buffer TEST {
	uint counter;
} test; 

layout(set = 0, binding = 1) volatile buffer OUT_BUF_1 {
	uint x[];
} out_buf1; 
layout(set = 0, binding = 2) volatile buffer OUT_BUF_2 {
	uint y[];
} out_buf2; 

layout(set = 0, binding = 3) volatile buffer BARRIER_STATE {
	uint flags[];
} bar_state; 

layout(local_size_x = 128, local_size_y = 1, local_size_z = 1) in;

void main()
{
	 uint subgroup_size = gl_SubgroupSize;
	 uint subgroup_id = gl_SubgroupID;
	 uint workgroup_id = gl_WorkGroupID.x;
	 uint num_workgroups = gl_NumWorkGroups.x;
	uint gid_x = gl_GlobalInvocationID.x;
	uint pc = 0u;
	uint round_robin = 0u;

	uint num_testing_subgroups = 2;
	uint active_workgroups = num_workgroups - (num_workgroups % num_testing_subgroups);
	uint chunk_size = (num_workgroups >= num_testing_subgroups) ? (num_workgroups / num_testing_subgroups) : 1u;
	uint index = workgroup_id % chunk_size;

	if (workgroup_id < active_workgroups && workgroup_id / chunk_size == 0 && subgroup_id == 0) { 
	   int terminate = 0;

	while (true) {
	   if (subgroupAny(terminate == 1)) {
	   break;
	}
	uint pick_thread = uint(round_robin % subgroup_size);
	if (pick_thread == gl_SubgroupInvocationID) {
	  switch(pc) {

	  case 0: 
		atomicExchange(out_buf1.x[index], 1);
		pc = pc + 1;
		break;

	  case 1: 
		if (atomicExchange(out_buf1.x[index], 1) ==  0) { 
		   pc = 0u;
		}
		else {
		   pc = pc + 1u;
		}
		break;

	  case 2:
		terminate = 1;
		break;

	     }
	   }
	   round_robin += 1u;
	   pc = subgroupShuffle(pc, pick_thread);
	}
	}

	if (workgroup_id < active_workgroups && workgroup_id / chunk_size == 1 && subgroup_id == 0) { 
	   int terminate = 0;

	while (true) {
	   if (subgroupAny(terminate == 1)) {
	   break;
	}
	uint pick_thread = uint(round_robin % subgroup_size);
	if (pick_thread == gl_SubgroupInvocationID) {
	  switch(pc) {

	  case 0: 
		if (atomicExchange(out_buf1.x[index], 0) ==  0) { 
		   pc = 0u;
		}
		else {
		   pc = pc + 1u;
		}
		break;

	  case 1:
		terminate = 1;
		break;

	     }
	   }
	   round_robin += 1u;
	   pc = subgroupShuffle(pc, pick_thread);
	}
	}

	barrier();
	if (workgroup_id == 0u) {
		for (uint peer = gl_LocalInvocationID.x + 1u; peer < num_workgroups; peer += gl_WorkGroupSize.x) {
			while (atomicLoad(bar_state.flags[peer], gl_ScopeDevice, gl_StorageSemanticsBuffer, gl_SemanticsAcquire) == 0u) {
			}
		}
		barrier();
		for (uint peer = gl_LocalInvocationID.x + 1u; peer < num_workgroups; peer += gl_WorkGroupSize.x) {
			atomicStore(bar_state.flags[peer], 0u, gl_ScopeDevice, gl_StorageSemanticsBuffer, gl_SemanticsRelease);
		}
	}
	else {
		if (gl_LocalInvocationID.x == 0u) {
			atomicStore(bar_state.flags[workgroup_id], 1u, gl_ScopeDevice, gl_StorageSemanticsBuffer, gl_SemanticsRelease);
			while (atomicLoad(bar_state.flags[workgroup_id], gl_ScopeDevice, gl_StorageSemanticsBuffer, gl_SemanticsAcquire) == 1u) {
			}
		}
	}
	barrier();
	atomicAdd(test.counter, 1);
}
END

BUFFER tester DATA_TYPE uint32 SIZE 1 FILL 0
BUFFER out1 DATA_TYPE uint32 SIZE NUMWORKGROUPS FILL 0
BUFFER out2 DATA_TYPE uint32 SIZE NUMWORKGROUPS FILL 0
BUFFER bar_state DATA_TYPE uint32 SIZE NUMWORKGROUPS FILL 0

PIPELINE compute test_pipe
  ATTACH test
  BIND BUFFER tester AS storage DESCRIPTOR_SET 0 BINDING 0 
  BIND BUFFER out1 AS storage DESCRIPTOR_SET 0 BINDING 1 
  BIND BUFFER out2 AS storage DESCRIPTOR_SET 0 BINDING 2 
  BIND BUFFER bar_state AS storage DESCRIPTOR_SET 0 BINDING 3 

END

RUN test_pipe NUMWORKGROUPS 1 1
EXPECT tester IDX 0 EQ TOTALTHREADS
