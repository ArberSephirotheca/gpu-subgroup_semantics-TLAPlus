#!amber

SET ENGINE_DATA fence_timeout_ms 10000

SHADER compute test GLSL
#version 460
#extension GL_KHR_shader_subgroup_basic : enable
#extension GL_KHR_shader_subgroup_ballot : enable
#extension GL_KHR_shader_subgroup_vote : enable
#extension GL_KHR_shader_subgroup_basic : enable

layout(set = 0, binding = 3) volatile buffer PICKTHREAD {
	uint pick_thread;
} pickthread;

layout(set = 0, binding = 0) volatile buffer TEST {
	uint counter;
} test; 

layout(set = 0, binding = 1) volatile buffer OUT_BUF_1 {
	uint x[];
} out_buf1; 
layout(set = 0, binding = 2) volatile buffer OUT_BUF_2 {
	uint y[];
} out_buf2; 

layout(local_size_x = 128, local_size_y = 1, local_size_z = 1) in;

void main()
{
	 uint subgroup_size = gl_SubgroupSize;
	 uint subgroup_id = gl_SubgroupID;
	 uint workgroup_id = gl_WorkGroupID.x;
	 uint num_workgroups = gl_NumWorkGroups.x;
	uint gid_x = gl_GlobalInvocationID.x;
	uint pc = 0u;
	uint round_robin = 0u;

	uint num_testing_subgroups = 2;
	uint chooped_workgroup_offset = num_workgroups % num_testing_subgroups;
	 if (workgroup_id + chooped_workgroup_offset >= num_workgroups) {
		 return;
	 }
	uint index = workgroup_id / num_testing_subgroups;

	if (workgroup_id % num_testing_subgroups == 0 && subgroup_id == 0) { 
	   int terminate = 0;

	while (true) {
	   if (subgroupAny(terminate == 1)) {
	   break;
	}
	pickthread.pick_thread = uint(round_robin % subgroup_size);
	if (pickthread.pick_thread == gl_SubgroupInvocationID) {
	  switch(pc) {

	  case 0: 
		if (atomicExchange(out_buf1.x[index], 1) ==  0) { 
		   pc = 0u;
		}
		else {
		   pc = pc + 1u;
		}
		break;

	  case 1:
		terminate = 1;
		break;

	     }
	   }
	   round_robin += 1u;
	   pc = subgroupBroadcast(pc, pickthread.pick_thread);
	}
	}

	if (workgroup_id % num_testing_subgroups == 1 && subgroup_id == 0) { 
	   int terminate = 0;

	while (true) {
	   if (subgroupAny(terminate == 1)) {
	   break;
	}
	pickthread.pick_thread = uint(round_robin % subgroup_size);
	if (pickthread.pick_thread == gl_SubgroupInvocationID) {
	  switch(pc) {

	  case 0: 
		if (atomicExchange(out_buf1.x[index], 0) ==  1) { 
		   pc = 0u;
		}
		else {
		   pc = pc + 1u;
		}
		break;

	  case 1: 
		if (atomicExchange(out_buf1.x[index], 0) ==  1) { 
		   pc = 1u;
		}
		else {
		   pc = pc + 1u;
		}
		break;

	  case 2:
		terminate = 1;
		break;

	     }
	   }
	   round_robin += 1u;
	   pc = subgroupBroadcast(pc, pickthread.pick_thread);
	}
	}

barrier();
	atomicAdd(test.counter, 1);
}
END

BUFFER pickthread DATA_TYPE uint32 SIZE 1 FILL 0
BUFFER tester DATA_TYPE uint32 SIZE 1 FILL 0
BUFFER out1 DATA_TYPE uint32 SIZE 65535 FILL 0
BUFFER out2 DATA_TYPE uint32 SIZE 65535 FILL 0

PIPELINE compute test_pipe
  ATTACH test
  BIND BUFFER pickthread AS storage DESCRIPTOR_SET 0 BINDING 3 
  BIND BUFFER tester AS storage DESCRIPTOR_SET 0 BINDING 0 
  BIND BUFFER out1 AS storage DESCRIPTOR_SET 0 BINDING 1 
  BIND BUFFER out2 AS storage DESCRIPTOR_SET 0 BINDING 2 

END

RUN test_pipe 65532 1 1
EXPECT tester IDX 0 EQ 8388096
